<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Calendrier Coupe du Monde 2026</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', sans-serif;
    background: #0a1628;
    color: #fff;
    min-height: 100vh;
  }

  header {
    background: linear-gradient(135deg, #c8102e, #1a1a2e);
    padding: 28px 24px 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  header::before {
    content: '⚽';
    position: absolute;
    font-size: 120px;
    opacity: 0.06;
    top: -20px; right: -20px;
  }
  header h1 { font-size: 2rem; font-weight: 800; letter-spacing: 1px; }
  header p { color: #ffcc00; font-size: 0.95rem; margin-top: 6px; font-weight: 600; }

  .legend {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    padding: 14px 20px;
    background: #111b30;
    border-bottom: 1px solid #1e2d48;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 0.82rem;
    color: #9eb4d4;
  }
  .dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
  .dot-m6 { background: #e8a800; }
  .dot-bein { background: #00a651; }
  .dot-both { background: linear-gradient(135deg, #e8a800 50%, #00a651 50%); }
  .dot-fr { background: #c8102e; }

  .filters {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
    padding: 14px 20px;
    background: #0d1e38;
  }
  .filter-btn {
    padding: 6px 16px;
    border-radius: 20px;
    border: 1px solid #2a3f60;
    background: transparent;
    color: #9eb4d4;
    cursor: pointer;
    font-size: 0.82rem;
    transition: all .2s;
  }
  .filter-btn:hover, .filter-btn.active {
    background: #c8102e;
    border-color: #c8102e;
    color: #fff;
  }

  .container { max-width: 900px; margin: 0 auto; padding: 20px 16px 40px; }

  .phase-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffcc00;
    margin: 28px 0 10px;
    padding-left: 12px;
    border-left: 3px solid #ffcc00;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .day-group { margin-bottom: 6px; }
  .day-header {
    font-size: 0.78rem;
    color: #5a7aa0;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 10px 12px 4px;
  }

  .match-card {
    background: #111b30;
    border: 1px solid #1e2d48;
    border-radius: 10px;
    padding: 14px 16px;
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: border-color .2s;
    position: relative;
  }
  .match-card:hover { border-color: #2a4a7f; }
  .match-card.france-match { border-left: 3px solid #c8102e; background: #16203a; }
  .match-card.hidden { display: none; }

  .match-time {
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffcc00;
    min-width: 48px;
    text-align: center;
  }
  .match-time.night { color: #ff6b6b; }

  .match-teams {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.95rem;
    font-weight: 600;
  }
  .team { flex: 1; text-align: right; }
  .team.right { text-align: left; }
  .vs {
    color: #5a7aa0;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 2px 6px;
    background: #0d1e38;
    border-radius: 4px;
  }

  .match-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    min-width: 90px;
  }
  .group-badge {
    font-size: 0.7rem;
    color: #5a7aa0;
    text-transform: uppercase;
  }
  .tv-badges { display: flex; gap: 4px; flex-wrap: wrap; justify-content: flex-end; }
  .tv-badge {
    font-size: 0.68rem;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 10px;
  }
  .tv-m6 { background: #e8a800; color: #000; }
  .tv-bein { background: #00a651; color: #fff; }
  .france-star {
    position: absolute;
    top: 8px; left: 8px;
    font-size: 0.65rem;
    color: #c8102e;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .stats-bar {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
    background: #111b30;
    border-top: 1px solid #1e2d48;
    padding: 14px;
    font-size: 0.82rem;
    color: #9eb4d4;
  }
  .stat strong { color: #fff; }

  @media (max-width: 600px) {
    .match-card { flex-wrap: wrap; }
    .match-meta { min-width: auto; }
    header h1 { font-size: 1.4rem; }
  }
</style>
</head>
